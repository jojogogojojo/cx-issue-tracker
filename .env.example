# ===========================================
# Issue Tracker — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in actual values.
# NEVER commit .env or .env.local files.

# ── 채널톡 API ─────────────────────────────────────────────────────────────────
CHANNELTALK_ACCESS_KEY=your_channeltalk_access_key
CHANNELTALK_ACCESS_SECRET=your_channeltalk_access_secret
# CHANNELTALK_API_BASE_URL=https://api.channel.io
CHANNELTALK_APP_TOKEN=your_channeltalk_app_token

# ── Anthropic API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# ── Google Calendar (OAuth) ────────────────────────────────────────────────────
# OAuth 2.0 Client ID (Web application type, redirect URI: developers.google.com/oauthplayground)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# OAuth Playground에서 발급받은 refresh token (Offline access)
GOOGLE_REFRESH_TOKEN=1//xxxxx
# 이슈 등록 대상 캘린더 ID
GOOGLE_CALENDAR_ID=c_xxxxx@group.calendar.google.com

# ── 채널톡 Desk URL ────────────────────────────────────────────────────────────
# DESK_BASE_URL=https://desk.channel.io

# ── Cron 인증 ──────────────────────────────────────────────────────────────────
# GitHub Actions cron이 /api/alert, /api/poll-replies 호출 시 사용할 토큰
TRIGGER_SECRET=generate_with_openssl_rand_base64_32

# ── 알림 그룹방 ────────────────────────────────────────────────────────────────
# 미설정 시 테스트방(356599) 사용. 운영방(346333)은 명시 설정 필요.
# ISSUE_TRACKER_ALERT_GROUP_ID=356599
